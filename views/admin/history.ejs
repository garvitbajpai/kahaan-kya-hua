<%- include('../partials/head', { title: 'Upload History — KKH Admin' }) %>

<body class="bg-gray-100 text-gray-900 font-sans">
<%- include('nav', { activePage: 'history' }) %>

<div class="max-w-5xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold font-serif text-gray-900">Upload History</h1>
      <p class="text-gray-500 text-sm mt-1"><%= history.length %> history total</p>
    </div>
    <a href="/admin/upload" class="bg-brand-red text-white px-5 py-2.5 rounded-xl font-semibold text-sm hover:bg-red-700 transition-colors">+ New Upload</a>
  </div>

  <% if (history.length === 0) { %>
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-16 text-center">
    <div class="text-6xl mb-4">📤</div>
    <h2 class="text-xl font-bold text-gray-700 mb-2">No history yet</h2>
    <p class="text-gray-500 mb-6">Upload your first Excel file to get started.</p>
    <a href="/admin/upload" class="inline-block bg-brand-red text-white px-6 py-3 rounded-xl font-semibold hover:bg-red-700 transition-colors">Upload Excel →</a>
  </div>
  <% } else { %>
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 border-b border-gray-100">
        <tr>
          <th class="px-5 py-3 text-left text-xs text-gray-500 font-semibold uppercase tracking-wide">File</th>
          <th class="px-5 py-3 text-left text-xs text-gray-500 font-semibold uppercase tracking-wide">Date</th>
          <th class="px-5 py-3 text-left text-xs text-gray-500 font-semibold uppercase tracking-wide">Rows</th>
          <th class="px-5 py-3 text-left text-xs text-gray-500 font-semibold uppercase tracking-wide">Status</th>
          <th class="px-5 py-3 text-left text-xs text-gray-500 font-semibold uppercase tracking-wide">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50">
        <% history.forEach(u => { %>
        <tr class="hover:bg-gray-50 transition-colors">
          <td class="px-5 py-4">
            <p class="font-medium text-gray-800"><%= u.filename %></p>
          </td>
          <td class="px-5 py-4 text-xs text-gray-500 whitespace-nowrap">
            <%= new Date(u.uploadedAt).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
          </td>
          <td class="px-5 py-4">
            <div class="text-xs">
              <span class="text-green-600 font-semibold"><%= u.successCount %></span>
              <span class="text-gray-400"> / </span>
              <span class="text-gray-600"><%= u.totalRows %> total</span>
              <% if (u.failureCount > 0) { %>
              <span class="text-red-500 ml-1">(<%= u.failureCount %> failed)</span>
              <% } %>
            </div>
            <!-- Progress bar -->
            <div class="mt-1.5 w-full bg-gray-100 rounded-full h-1.5">
              <div class="bg-green-500 h-1.5 rounded-full" style="width:<%= u.totalRows > 0 ? Math.round(u.successCount/u.totalRows*100) : 0 %>%"></div>
            </div>
          </td>
          <td class="px-5 py-4">
            <span class="text-xs font-bold uppercase px-2 py-1 rounded-full <%= u.status === 'success' ? 'bg-green-100 text-green-700' : u.status === 'partial' ? 'bg-yellow-100 text-yellow-700' : 'bg-red-100 text-red-700' %>"><%= u.status %></span>
          </td>
          <td class="px-5 py-4">
            <form method="POST" action="/admin/history/<%= u.id %>/delete" onsubmit="return confirm('Delete this upload record? Articles will NOT be deleted.')">
              <button type="submit" class="text-xs text-red-400 hover:text-red-600 font-medium transition-colors">Delete record</button>
            </form>
          </td>
        </tr>
        <% if (u.errorLog && u.failureCount > 0) { %>
        <tr class="bg-red-50">
          <td colspan="5" class="px-5 py-2">
            <details class="text-xs text-red-600">
              <summary class="cursor-pointer font-medium">Show error details (<%= u.failureCount %> rows failed)</summary>
              <div class="mt-2 space-y-0.5 pl-3">
                <% (typeof u.errorLog === 'string' ? JSON.parse(u.errorLog) : u.errorLog).forEach(e => { %>
                <p>Row <%= e.row %>: <%= e.message %></p>
                <% }) %>
              </div>
            </details>
          </td>
        </tr>
        <% } %>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>

</div>

</body></html>
