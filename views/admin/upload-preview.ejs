<%- include('../partials/head', { title: 'Preview Upload — KKH Admin' }) %>

<body class="bg-gray-100 text-gray-900 font-sans">
<%- include('nav', { activePage: 'upload' }) %>

<div class="max-w-7xl mx-auto px-4 py-8">
  <div class="flex items-center gap-4 mb-6">
    <a href="/admin/upload" class="text-sm text-gray-500 hover:text-brand-red transition-colors">← Back</a>
    <div>
      <h1 class="text-2xl font-bold font-serif text-gray-900">Preview: <%= filename %></h1>
      <p class="text-gray-500 text-sm mt-0.5"><%= valid.length %> valid · <%= errors.length %> errors</p>
    </div>
  </div>

  <% if (errors.length > 0) { %>
  <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-5 mb-6">
    <h2 class="text-sm font-bold text-yellow-800 mb-3">⚠ <%= errors.length %> rows with issues (will be skipped)</h2>
    <div class="space-y-1 max-h-40 overflow-y-auto">
      <% errors.forEach(e => { %>
      <p class="text-xs text-yellow-700">Row <%= e.row %>: <%= e.message %></p>
      <% }) %>
    </div>
  </div>
  <% } %>

  <% if (valid.length === 0) { %>
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-10 text-center">
    <div class="text-5xl mb-3">😞</div>
    <h2 class="text-xl font-bold text-gray-700 mb-2">No valid rows found</h2>
    <p class="text-gray-500 mb-6">Please check your Excel file format and try again.</p>
    <a href="/admin/upload" class="inline-block bg-brand-red text-white px-6 py-3 rounded-xl font-semibold hover:bg-red-700 transition-colors">Try Again</a>
  </div>
  <% } else { %>

  <!-- Summary -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
    <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100 text-center">
      <div class="text-2xl font-bold text-green-600"><%= valid.length %></div>
      <div class="text-xs text-gray-500 mt-1">Will Import</div>
    </div>
    <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100 text-center">
      <div class="text-2xl font-bold text-orange-500"><%= errors.length %></div>
      <div class="text-xs text-gray-500 mt-1">Skipped</div>
    </div>
    <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100 text-center">
      <div class="text-2xl font-bold text-brand-navy"><%= valid.filter(r => r.language === 'Hindi').length %></div>
      <div class="text-xs text-gray-500 mt-1">Hindi</div>
    </div>
    <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-100 text-center">
      <div class="text-2xl font-bold text-blue-600"><%= valid.filter(r => r.language === 'English').length %></div>
      <div class="text-xs text-gray-500 mt-1">English</div>
    </div>
  </div>

  <!-- Preview table -->
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-6">
    <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
      <h2 class="text-sm font-bold text-gray-700">Preview (first <%= Math.min(valid.length, 10) %> of <%= valid.length %> rows)</h2>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-xs">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-2.5 text-left text-gray-500 font-semibold uppercase tracking-wide">#</th>
            <th class="px-4 py-2.5 text-left text-gray-500 font-semibold uppercase tracking-wide">Headline</th>
            <th class="px-4 py-2.5 text-left text-gray-500 font-semibold uppercase tracking-wide">Category</th>
            <th class="px-4 py-2.5 text-left text-gray-500 font-semibold uppercase tracking-wide">Date</th>
            <th class="px-4 py-2.5 text-left text-gray-500 font-semibold uppercase tracking-wide">Lang</th>
            <th class="px-4 py-2.5 text-left text-gray-500 font-semibold uppercase tracking-wide">Priority</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% valid.slice(0,10).forEach((row, i) => { %>
          <tr class="hover:bg-gray-50 transition-colors">
            <td class="px-4 py-2.5 text-gray-400"><%= i + 1 %></td>
            <td class="px-4 py-2.5 text-gray-800 max-w-xs"><div class="line-clamp-2"><%= row.headline %></div></td>
            <td class="px-4 py-2.5"><span class="px-2 py-0.5 rounded bg-gray-100 text-gray-700"><%= row.categoryName %></span></td>
            <td class="px-4 py-2.5 text-gray-500"><%= new Date(row.date).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %></td>
            <td class="px-4 py-2.5"><span class="px-1.5 py-0.5 rounded text-white text-[9px] font-bold <%= row.language === 'Hindi' ? 'bg-orange-600' : 'bg-blue-600' %>"><%= row.language === 'Hindi' ? 'हिं' : 'EN' %></span></td>
            <td class="px-4 py-2.5 text-gray-600"><%= row.priority %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Confirm form -->
  <form method="POST" action="/admin/upload">
    <input type="hidden" name="confirm" value="true"/>
    <input type="hidden" name="previewData" value="<%- JSON.stringify(valid).replace(/"/g, '&quot;') %>"/>
    <input type="hidden" name="filename" value="<%= filename %>"/>
    <div class="flex gap-3">
      <a href="/admin/upload" class="flex-1 text-center border border-gray-200 text-gray-700 py-3 rounded-xl font-semibold hover:border-gray-400 transition-colors">Cancel</a>
      <button type="submit" class="flex-1 bg-green-600 text-white py-3 rounded-xl font-semibold hover:bg-green-700 transition-colors">
        ✓ Import <%= valid.length %> Articles
      </button>
    </div>
  </form>
  <% } %>

</div>
</body></html>
