<%- include('../partials/head', { title: 'Articles — KKH Admin' }) %>

<body class="bg-gray-100 text-gray-900 font-sans">
<%- include('nav', { activePage: 'articles' }) %>

<div class="max-w-7xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold font-serif text-gray-900">Articles</h1>
      <p class="text-gray-500 text-sm mt-1"><%= total %> total articles</p>
    </div>
    <a href="/admin/upload" class="bg-brand-red text-white px-5 py-2.5 rounded-xl font-semibold text-sm hover:bg-red-700 transition-colors">+ Upload Excel</a>
  </div>

  <!-- Filters -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 mb-6">
    <form method="GET" action="/admin/articles" class="flex flex-wrap gap-3">
      <input type="text" name="q" value="<%= filters.q %>" placeholder="Search headlines…"
        class="border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-brand-red flex-1 min-w-32"/>
      <select name="lang" class="border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-brand-red">
        <option value="">All Languages</option>
        <option value="Hindi" <%= filters.lang === 'Hindi' ? 'selected' : '' %>>Hindi</option>
        <option value="English" <%= filters.lang === 'English' ? 'selected' : '' %>>English</option>
      </select>
      <select name="cat" class="border border-gray-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-brand-red">
        <option value="">All Categories</option>
        <% categories.forEach(c => { %>
        <option value="<%= c.id %>" <%= filters.cat == c.id ? 'selected' : '' %>><%= c.name %></option>
        <% }) %>
      </select>
      <button type="submit" class="bg-brand-navy text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-blue-900 transition-colors">Filter</button>
      <a href="/admin/articles" class="text-sm text-gray-500 px-3 py-2 hover:text-brand-red transition-colors">Clear</a>
    </form>
  </div>

  <!-- Table -->
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    <% if (articles.length === 0) { %>
    <div class="text-center py-16">
      <div class="text-5xl mb-3">📭</div>
      <p class="text-gray-500">No articles found.</p>
    </div>
    <% } else { %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-100">
          <tr>
            <th class="px-4 py-3 text-left text-xs text-gray-500 font-semibold uppercase tracking-wide">Headline</th>
            <th class="px-4 py-3 text-left text-xs text-gray-500 font-semibold uppercase tracking-wide">Category</th>
            <th class="px-4 py-3 text-left text-xs text-gray-500 font-semibold uppercase tracking-wide">Date</th>
            <th class="px-4 py-3 text-left text-xs text-gray-500 font-semibold uppercase tracking-wide">Lang</th>
            <th class="px-4 py-3 text-left text-xs text-gray-500 font-semibold uppercase tracking-wide">P</th>
            <th class="px-4 py-3 text-left text-xs text-gray-500 font-semibold uppercase tracking-wide">Views</th>
            <th class="px-4 py-3 text-left text-xs text-gray-500 font-semibold uppercase tracking-wide">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% articles.forEach(a => { %>
          <tr class="hover:bg-gray-50 transition-colors">
            <td class="px-4 py-3 max-w-xs">
              <a href="/article/<%= a.slug %>" target="_blank" class="font-medium text-gray-800 hover:text-brand-red transition-colors line-clamp-2 block"><%= a.headline %></a>
              <% if (a.isBreaking) { %><span class="text-[9px] font-bold uppercase bg-red-100 text-red-700 px-1.5 py-0.5 rounded mt-1 inline-block">Breaking</span><% } %>
            </td>
            <td class="px-4 py-3">
              <span class="text-xs px-2 py-0.5 rounded text-white font-medium" style="background:<%= a.category.color || '#6B7280' %>"><%= a.category.name %></span>
            </td>
            <td class="px-4 py-3 text-xs text-gray-500 whitespace-nowrap"><%= new Date(a.publishedAt).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %></td>
            <td class="px-4 py-3"><span class="text-[9px] font-bold uppercase px-1.5 py-0.5 rounded text-white <%= a.language === 'Hindi' ? 'bg-orange-600' : 'bg-blue-600' %>"><%= a.language === 'Hindi' ? 'हिं' : 'EN' %></span></td>
            <td class="px-4 py-3"><span class="text-xs font-bold text-gray-600"><%= a.priority %></span></td>
            <td class="px-4 py-3 text-xs text-gray-500"><%= a.viewCount %></td>
            <td class="px-4 py-3">
              <form method="POST" action="/admin/articles/<%= a.id %>/delete" onsubmit="return confirm('Delete this article?')">
                <button type="submit" class="text-xs text-red-500 hover:text-red-700 font-medium transition-colors">Delete</button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <% if (totalPages > 1) { %>
    <div class="px-4 py-4 border-t border-gray-100 flex items-center justify-between">
      <p class="text-xs text-gray-500">Page <%= page %> of <%= totalPages %></p>
      <div class="flex items-center gap-2">
        <% if (page > 1) { %>
        <a href="?page=<%= page-1 %>&q=<%= filters.q %>&lang=<%= filters.lang %>&cat=<%= filters.cat %>" class="px-3 py-1.5 rounded-lg border border-gray-200 text-xs font-medium hover:border-brand-red hover:text-brand-red transition-colors">← Prev</a>
        <% } %>
        <% for(let i = Math.max(1, page-2); i <= Math.min(totalPages, page+2); i++) { %>
        <a href="?page=<%= i %>&q=<%= filters.q %>&lang=<%= filters.lang %>&cat=<%= filters.cat %>" class="px-3 py-1.5 rounded-lg text-xs font-medium transition-colors <%= i === page ? 'bg-brand-red text-white' : 'border border-gray-200 hover:border-brand-red hover:text-brand-red' %>"><%= i %></a>
        <% } %>
        <% if (page < totalPages) { %>
        <a href="?page=<%= page+1 %>&q=<%= filters.q %>&lang=<%= filters.lang %>&cat=<%= filters.cat %>" class="px-3 py-1.5 rounded-lg border border-gray-200 text-xs font-medium hover:border-brand-red hover:text-brand-red transition-colors">Next →</a>
        <% } %>
      </div>
    </div>
    <% } %>
    <% } %>
  </div>
</div>

</body></html>
