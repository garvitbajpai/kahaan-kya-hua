<div class="flex gap-3 py-3 border-b border-gray-100 last:border-0 group">
  <div class="flex-1 min-w-0">
    <div class="flex items-center gap-1.5 mb-1">
      <span class="text-[9px] font-bold uppercase px-1.5 py-0.5 rounded text-white" style="background:<%= a.category.color || '#6B7280' %>"><%= a.category.name %></span>
      <% if (a.isBreaking) { %><span class="text-[9px] font-black uppercase bg-red-600 text-white px-1.5 py-0.5 rounded">Breaking</span><% } %>
    </div>
    <a href="/article/<%= a.slug %>">
      <p class="text-sm font-semibold text-gray-800 group-hover:text-brand-red transition-colors line-clamp-2 leading-snug"><%= a.headline %></p>
    </a>
    <div class="flex items-center gap-2 mt-1 text-xs text-gray-400">
      <span><%= h.timeAgo(a.publishedAt) %></span>
      <span class="px-1 py-0.5 rounded text-[9px] font-bold text-white <%= a.language === 'Hindi' ? 'bg-orange-600' : 'bg-blue-600' %>"><%= a.language === 'Hindi' ? 'हिं' : 'EN' %></span>
    </div>
  </div>
</div>
