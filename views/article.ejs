<%- include('partials/head', { title }) %>
<%- include('partials/header', { ticker, categories, q: '' }) %>

<div class="bg-gray-50 min-h-screen">
<div class="max-w-7xl mx-auto px-4 py-8">

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

    <!-- Article main -->
    <div class="lg:col-span-2">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-xs text-gray-400 mb-6">
        <a href="/" class="hover:text-brand-red transition-colors">Home</a>
        <span>›</span>
        <a href="/category/<%= article.category.slug %>" class="hover:text-brand-red transition-colors"><%= article.category.name %></a>
        <span>›</span>
        <span class="text-gray-600 line-clamp-1"><%= article.headline.slice(0,60) %>…</span>
      </nav>

      <article class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
        <!-- Hero banner -->
        <div class="p-6 md:p-10" style="background:linear-gradient(135deg,#1A237E,#0D0D0D)">
          <div class="flex flex-wrap items-center gap-2 mb-4">
            <span class="text-[9px] font-black uppercase tracking-widest px-2 py-0.5 rounded text-white" style="background:<%= h.priorityBg(article.priority) %>"><%= h.priorityLabel(article.priority) %></span>
            <span class="text-xs px-2 py-0.5 rounded text-white font-medium" style="background:<%= article.category.color || '#6B7280' %>"><%= article.category.name %></span>
            <% if (article.isBreaking) { %><span class="text-[9px] font-black uppercase tracking-widest bg-red-600 text-white px-2 py-0.5 rounded animate-pulse">ब्रेकिंग</span><% } %>
            <span class="px-2 py-0.5 rounded text-[10px] font-bold text-white <%= article.language === 'Hindi' ? 'bg-orange-600' : 'bg-blue-600' %>"><%= article.language === 'Hindi' ? 'हिंदी' : 'English' %></span>
          </div>
          <h1 class="font-serif text-2xl md:text-3xl lg:text-4xl font-bold leading-tight text-white mb-4"><%= article.headline %></h1>
          <div class="flex flex-wrap items-center gap-4 text-xs text-blue-300">
            <span><%= h.formatDate(article.publishedAt) %></span>
            <span>·</span>
            <span><%= h.getReadTime(article.body) %> min read</span>
            <span>·</span>
            <span><%= article.viewCount %> views</span>
          </div>
        </div>

        <!-- Body -->
        <div class="p-6 md:p-10">
          <div class="prose prose-lg max-w-none text-gray-800 leading-relaxed">
            <% article.body.split('\n').filter(p => p.trim()).forEach(para => { %>
            <p class="mb-4 text-base md:text-lg"><%= para %></p>
            <% }) %>
          </div>

          <!-- Tags -->
          <div class="mt-8 pt-6 border-t border-gray-100 flex flex-wrap items-center gap-3">
            <span class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Category:</span>
            <a href="/category/<%= article.category.slug %>" class="text-xs px-3 py-1.5 rounded-full text-white font-medium hover:opacity-80 transition-opacity" style="background:<%= article.category.color || '#6B7280' %>"><%= article.category.name %></a>
          </div>
        </div>
      </article>

      <!-- Related -->
      <% if (related.length > 0) { %>
      <section class="mt-8">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-1 h-6 bg-brand-red rounded-full"></div>
          <h2 class="text-xl font-serif font-bold text-gray-900">Related Stories</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <% related.forEach(a => { %><%- include('partials/article-card', { a, h }) %><% }) %>
        </div>
      </section>
      <% } %>
    </div>

    <!-- Sidebar -->
    <div class="space-y-6">
      <!-- Related in category -->
      <% if (related.length > 0) { %>
      <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5">
        <h2 class="flex items-center gap-2 text-xs font-black uppercase tracking-widest text-gray-400 mb-4">
          <span class="w-2 h-2 rounded-full inline-block" style="background:<%= article.category.color || '#DC2626' %>"></span> More in <%= article.category.name %>
        </h2>
        <% related.forEach(a => { %>
        <%- include('partials/article-row', { a, h }) %>
        <% }) %>
        <a href="/category/<%= article.category.slug %>" class="mt-3 inline-block text-xs font-medium text-brand-red hover:underline">All <%= article.category.name %> →</a>
      </div>
      <% } %>

      <!-- All categories -->
      <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5">
        <h2 class="text-xs font-black uppercase tracking-widest text-gray-400 mb-4">Categories</h2>
        <div class="flex flex-wrap gap-2">
          <% categories.forEach(cat => { %>
          <a href="/category/<%= cat.slug %>" class="text-xs px-3 py-1.5 rounded-full text-white font-medium hover:opacity-80 transition-opacity" style="background:<%= cat.color || '#6B7280' %>"><%= cat.name %></a>
          <% }) %>
        </div>
      </div>
    </div>

  </div>
</div>
</div>

<%- include('partials/footer', { categories }) %>
