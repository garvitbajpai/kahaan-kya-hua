<%- include('partials/head', { title }) %>
<%- include('partials/header', { ticker, categories, q }) %>

<div class="bg-gray-50 min-h-screen">
<div class="max-w-7xl mx-auto px-4 py-8">

  <!-- Search header -->
  <div class="mb-8">
    <h1 class="text-2xl font-serif font-bold text-gray-900 mb-1">
      <% if (q) { %>Search results for "<%= q %>"<% } else { %>Search<% } %>
    </h1>
    <% if (q) { %><p class="text-gray-500 text-sm"><%= results.length %> article<%= results.length !== 1 ? 's' : '' %> found</p><% } %>
  </div>

  <!-- Search bar -->
  <form action="/search" method="GET" class="mb-8">
    <div class="flex gap-3 max-w-2xl">
      <input type="search" name="q" value="<%= q %>" placeholder="खोजें — Search results…"
        class="flex-1 border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-brand-red shadow-sm"/>
      <button type="submit" class="bg-brand-red text-white rounded-xl px-6 py-3 text-sm font-semibold hover:bg-red-700 transition-colors">Search</button>
    </div>
  </form>

  <% if (!q) { %>
  <div class="text-center py-16">
    <div class="text-6xl mb-4">🔍</div>
    <h2 class="text-xl font-serif font-bold text-gray-700 mb-2">What are you looking for?</h2>
    <p class="text-gray-500">Enter a keyword above to search all results.</p>
  </div>
  <% } else if (results.length === 0) { %>
  <div class="text-center py-16">
    <div class="text-6xl mb-4">😕</div>
    <h2 class="text-xl font-serif font-bold text-gray-700 mb-2">No results found</h2>
    <p class="text-gray-500">Try different keywords or browse by category.</p>
    <div class="mt-6 flex flex-wrap justify-center gap-2">
      <% categories.forEach(cat => { %>
      <a href="/category/<%= cat.slug %>" class="text-xs px-3 py-1.5 rounded-full text-white font-medium hover:opacity-80 transition-opacity" style="background:<%= cat.color || '#6B7280' %>"><%= cat.name %></a>
      <% }) %>
    </div>
  </div>
  <% } else { %>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    <% results.forEach(a => { %><%- include('partials/article-card', { a, h }) %><% }) %>
  </div>
  <% } %>

</div>
</div>

<%- include('partials/footer', { categories }) %>
