<%- include('partials/head', { title: title || 'Error' }) %>
<%- include('partials/header', { ticker: [], categories: typeof categories !== 'undefined' ? categories : [], q: '' }) %>

<div class="bg-gray-50 min-h-screen flex items-center justify-center">
  <div class="text-center max-w-lg mx-auto px-4 py-20">
    <div class="text-8xl font-serif font-bold text-gray-200 mb-4"><%= code || status || 500 %></div>
    <h1 class="text-2xl font-serif font-bold text-gray-900 mb-3"><%= title || 'Something went wrong' %></h1>
    <p class="text-gray-500 mb-8"><%= message || 'An unexpected error occurred.' %></p>
    <div class="flex items-center justify-center gap-4">
      <a href="/" class="px-6 py-3 bg-brand-red text-white rounded-xl font-semibold hover:bg-red-700 transition-colors">← Home</a>
      <a href="javascript:history.back()" class="px-6 py-3 border border-gray-200 rounded-xl font-semibold text-gray-700 hover:border-gray-400 transition-colors">Go Back</a>
    </div>
  </div>
</div>

<%- include('partials/footer', { categories: typeof categories !== 'undefined' ? categories : [] }) %>
