<%- include('partials/head', { title }) %>
<%- include('partials/header', { ticker, categories, q: '' }) %>

<div class="bg-gray-50 min-h-screen">
<div class="max-w-7xl mx-auto px-4 py-8">

  <!-- Category header -->
  <div class="mb-8 rounded-2xl p-6 md:p-10 text-white" style="background:linear-gradient(135deg,<%= category.color || '#1A237E' %>,#0D0D0D)">
    <nav class="flex items-center gap-2 text-xs text-white/60 mb-4">
      <a href="/" class="hover:text-white transition-colors">Home</a>
      <span>›</span>
      <span><%= category.name %></span>
    </nav>
    <h1 class="font-serif text-3xl md:text-4xl font-bold mb-2"><%= category.name %></h1>
    <% if (category.description) { %>
    <p class="text-white/70 text-sm md:text-base max-w-2xl"><%= category.description %></p>
    <% } %>
    <div class="mt-4 text-sm text-white/60"><%= total %> articles</div>
  </div>

  <% if (articles.length === 0) { %>
  <div class="text-center py-20">
    <div class="text-6xl mb-4">📭</div>
    <h2 class="text-2xl font-serif font-bold text-gray-700 mb-2">No articles yet</h2>
    <p class="text-gray-500">Check back soon for <%= category.name %> stories.</p>
  </div>
  <% } else { %>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <div class="lg:col-span-2">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
        <% articles.forEach(a => { %><%- include('partials/article-card', { a, h }) %><% }) %>
      </div>

      <!-- Pagination -->
      <% if (totalPages > 1) { %>
      <div class="flex items-center justify-center gap-2 mt-8">
        <% if (page > 1) { %>
        <a href="/category/<%= category.slug %>?page=<%= page-1 %>" class="px-4 py-2 rounded-lg border border-gray-200 text-sm font-medium hover:border-brand-red hover:text-brand-red transition-colors">← Prev</a>
        <% } %>
        <% for(let i = Math.max(1, page-2); i <= Math.min(totalPages, page+2); i++) { %>
        <a href="/category/<%= category.slug %>?page=<%= i %>" class="px-4 py-2 rounded-lg text-sm font-medium transition-colors <%= i === page ? 'bg-brand-red text-white' : 'border border-gray-200 hover:border-brand-red hover:text-brand-red' %>"><%= i %></a>
        <% } %>
        <% if (page < totalPages) { %>
        <a href="/category/<%= category.slug %>?page=<%= page+1 %>" class="px-4 py-2 rounded-lg border border-gray-200 text-sm font-medium hover:border-brand-red hover:text-brand-red transition-colors">Next →</a>
        <% } %>
      </div>
      <% } %>
    </div>

    <!-- Sidebar -->
    <div>
      <!-- All categories -->
      <div class="mt-6 bg-white rounded-xl border border-gray-100 shadow-sm p-5">
        <h2 class="text-xs font-black uppercase tracking-widest text-gray-400 mb-4">All Categories</h2>
        <div class="flex flex-wrap gap-2">
          <% categories.forEach(cat => { %>
          <a href="/category/<%= cat.slug %>" class="text-xs px-3 py-1.5 rounded-full text-white font-medium hover:opacity-80 transition-opacity" style="background:<%= cat.color || '#6B7280' %>"><%= cat.name %></a>
          <% }) %>
        </div>
      </div>
    </div>
  </div>
  <% } %>

</div>
</div>

<%- include('partials/footer', { categories }) %>
